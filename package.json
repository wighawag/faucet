{
  "name": "faucet-server-monorepo",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "devDependencies": {
    "@changesets/cli": "^2.30.0",
    "cross-var": "^1.1.0",
    "ldenv": "^0.5.0",
    "zellij-launcher": "^0.0.1"
  },
  "scripts": {
    "preinstall": "npx only-allow pnpm",
    "prepublishOnly": "pnpm format:check && pnpm build",
    "release": "pnpm prepublishOnly && git push --all && pnpm changeset publish && git push --tags",
    "---------------------- FORMAT ----------------------": "",
    "format": "pnpm -r format",
    "format:check": "pnpm -r format:check",
    "---------------------- DEV ----------------------": "",
    "cf-worker:dev": "pnpm --filter faucet-server-cf-worker dev",
    "nodejs:dev": "pnpm --filter faucet-server-nodejs dev",
    "server:dev": "pnpm --filter faucet-server-app dev",
    "frontend:dev": "pnpm --filter faucet-frontend dev",
    "---------------------- BUILD ----------------------": "",
    "build:frontend": "pnpm --filter faucet-frontend build",
    "build:server": "pnpm --filter faucet-server-app build",
    "build:copy-static:nodejs": "rm -rf platforms/nodejs/static && cp -r packages/frontend/dist platforms/nodejs/static",
    "build:copy-static:cf": "rm -rf platforms/cf-worker/static && cp -r packages/frontend/dist platforms/cf-worker/static",
    "build:copy-static": "pnpm build:copy-static:nodejs && pnpm build:copy-static:cf",
    "build": "pnpm build:frontend && pnpm build:copy-static && ldenv pnpm run -r build",
    "---------------------- DEPLOY ----------------------": "",
    "deploy:cf": "pnpm run --filter faucet-server-server-cf-worker deploy",
    "---------------------- RUN FULL LOCAL SETUP ----------------------": "",
    "stop": "cross-var zellij kill-session $npm_package_name",
    "start": "cross-var zellij-launcher a $npm_package_name || cross-var ldenv -d localhost zellij -n zellij.kdl -s $npm_package_name"
  }
}
