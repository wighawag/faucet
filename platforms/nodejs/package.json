{
  "name": "faucet-server",
  "version": "0.0.5",
  "publishConfig": {
    "access": "public"
  },
  "type": "module",
  "bin": {
    "faucet": "./dist/cli.js"
  },
  "files": [
    "dist",
    "src",
    "static"
  ],
  "dependencies": {
    "@hono/node-server": "^1.19.12",
    "@libsql/client": "^0.17.2",
    "commander": "^14.0.3",
    "faucet-server-app": "workspace:*",
    "ldenv": "^0.5.0",
    "named-logs-context": "^0.1.1",
    "remote-sql-libsql": "^0.0.7"
  },
  "devDependencies": {
    "@types/node": "^25.5.0",
    "as-soon": "^0.1.6",
    "set-defaults": "^0.0.5",
    "tsx": "^4.19.3",
    "typescript": "^5.9.3"
  },
  "scripts": {
    "prepare": "set-defaults .env.default",
    "prepublishOnly": "cp ../../README.md ./ && cp ../../LICENSE ./",
    "dev": "tsx watch src/cli.ts --port 30042",
    "build": "tsc",
    "build:watch": "as-soon -w src tsc"
  }
}