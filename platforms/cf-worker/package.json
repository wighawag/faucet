{
  "name": "faucet-server-cf-worker",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "files": [
    "src",
    "tsconfig.json"
  ],
  "dependencies": {
    "named-logs": "^0.4.1",
    "named-logs-context": "^0.1.1",
    "remote-sql-d1": "^0.0.6",
    "faucet-server-app": "workspace:*",
    "workers-logger": "0.2.1"
  },
  "devDependencies": {
    "@cloudflare/vitest-pool-workers": "^0.13.3",
    "@cloudflare/workers-types": "^4.20260317.1",
    "@types/node": "^25.5.0",
    "ldenv": "^0.3.16",
    "prettier": "^3.8.1",
    "set-defaults": "^0.0.5",
    "typescript": "^5.9.3",
    "vitest": "^4.1.0",
    "wrangler": "^4.76.0"
  },
  "scripts": {
    "prepare": "set-defaults .",
    "deploy:production": "wrangler -e production deploy --minify",
    "dev": "pnpm init-db && wrangler dev -e production --port 34005",
    "init-db": "ldenv wrangler -e production d1 execute template-agnostic-db --file=node_modules/faucet-server-app/src/schema/sql/db.sql ~~",
    "test": "vitest",
    "format:check": "prettier --check .",
    "format": "prettier --write ."
  }
}